# ============================================
# PANGOLIN RENDER MANAGER CONFIGURATION
# ============================================

# Ports
MANAGER_PORT=88
PROMETHEUS_PORT=9090
# NOTE: WEB_PORT and GRAFANA_PORT are no longer used — traffic now flows through
# Traefik on ports 80 (HTTP→HTTPS redirect) and 443 (HTTPS).

# ============================================
# TRAEFIK - Reverse Proxy
# ============================================

# Hostnames used by Traefik for routing (Host-based rules)
PANGOLIN_DOMAIN=pangolin.localhost
GRAFANA_DOMAIN=grafana.localhost

# TLS mode:
#   self-signed (default) – leave TRAEFIK_CERT_RESOLVER empty; Traefik generates
#     a built-in self-signed certificate. Suitable for local / private networks.
#   letsencrypt – set TRAEFIK_CERT_RESOLVER=letsencrypt and provide ACME_EMAIL.
#     The domain(s) above must be publicly reachable on port 80 for the
#     HTTP-01 challenge to succeed.
TRAEFIK_CERT_RESOLVER=

# Email for Let's Encrypt certificate notifications (only used when TRAEFIK_CERT_RESOLVER=letsencrypt)
ACME_EMAIL=admin@example.com

# Set to true to enable the Traefik dashboard on port 8080 (insecure – dev only)
TRAEFIK_DASHBOARD_ENABLED=false

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
# WARNING: Grafana admin password is now read from secrets/grafana_admin_password.txt
# The GRAFANA_ADMIN_PASSWORD variable is kept here for reference only and is no
# longer passed directly to the container.
# GRAFANA_ADMIN_PASSWORD=admin

# Grafana embedding (set to true to enable anonymous panel viewing in the Pangolin UI)
# Safe to enable on local/trusted networks. Review before exposing publicly.
GF_AUTH_ANONYMOUS_ENABLED=false
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
GF_SECURITY_ALLOW_EMBEDDING=false

# Monitoring
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_RETENTION=30d

# Flamenco worker scaling & resources
WORKER_REPLICAS=2
WORKER_CPU_LIMIT=4.0
WORKER_CPU_RESERVE=2.0
WORKER_MEM_LIMIT=8G
WORKER_MEM_RESERVE=4G

# Flamenco exporter tuning
EXPORTER_SCRAPE_INTERVAL=15
EXPORTER_WORKER_SCRAPE_INTERVAL=15
EXPORTER_TASK_SCRAPE_INTERVAL=60
EXPORTER_TASK_SAMPLE_MIN=3
EXPORTER_TASK_SAMPLE_MAX=5
EXPORTER_MAX_JOB_THRESHOLD=100
EXPORTER_REQUEST_TIMEOUT=10
EXPORTER_LOG_LEVEL=INFO

# GPU exporter tuning
GPU_EXPORTER_SCRAPE_INTERVAL=5
GPU_EXPORTER_LOG_LEVEL=INFO

# Features
# Set to true to enable job deletion (removes from Flamenco AND deletes output files from disk)
# WARNING: Deletion is irreversible. Only enable on trusted networks. Be very careful, please!!!
ENABLE_DELETE=false
# !!!

# Database
# WARNING: Change these credentials before deploying to any non-local environment!
# Passwords are now read from secret files (see secrets/README.md).
# Create secrets/postgres_password.txt with a strong password before starting.
POSTGRES_DB=pangolin
POSTGRES_USER=pangolin
# POSTGRES_PASSWORD is kept as a fallback for local dev without Docker secrets.
# It is NOT used when the secrets/ files are present.
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD