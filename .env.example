# ============================================================
# DOMAIN
# ============================================================
# Production:  DOMAIN=yourdomain.com
# Local test:  DOMAIN=<your-public-ip>.traefik.me  (get IP with: curl ifconfig.me)
#              then use: docker compose -f docker-compose.yml -f docker-compose.traefik-me.yml up -d
DOMAIN=your-ip.traefik.me
ACME_EMAIL=you@example.com     # Only used in production (not traefik.me)

# ============================================================
# KEYCLOAK
# ============================================================
KEYCLOAK_PG_PASS=change_me_keycloak_db_pass
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin_pass
KEYCLOAK_REALM=pholid         # Create this realm in Keycloak after first boot

# ============================================================
# PHOLID DATABASE (separate DB on the same Postgres instance)
# ============================================================
POSTGRES_DB=pholid
POSTGRES_USER=pholid
POSTGRES_PASSWORD=change_me_pholid_db_pass

# ============================================================
# PHOLID BACKEND
# ============================================================
PHOLID_AUTH_ENABLED=false     # Flip to true once Keycloak realm + client are set up
ENABLE_DELETE=false

# OIDC - fill these in after creating the pholid client in Keycloak
# Client type: confidential | Standard flow: on | Direct access: off
OIDC_CLIENT_ID=pholid
OIDC_CLIENT_SECRET=change_me_get_from_keycloak_client_credentials_tab

# ============================================================
# OAUTH2-PROXY (forward auth for Flamenco + Prometheus)
# ============================================================
# Create a separate confidential client in Keycloak for this (e.g. "pholid-proxy")
# Valid redirect URI: https://oauth2.<domain>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=pholid-proxy
OAUTH2_PROXY_CLIENT_SECRET=change_me_get_from_keycloak_client_credentials_tab
# Generate with: python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Result must decode to exactly 16, 24, or 32 bytes — use the command above, not a raw random string
OAUTH2_PROXY_COOKIE_SECRET=change_me_run_generation_command_above

# ============================================================
# GRAFANA
# ============================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_pass

# OIDC - fill in after creating the grafana client in Keycloak
# Client type: confidential | Standard flow: on
GRAFANA_OIDC_CLIENT_ID=grafana
GRAFANA_OIDC_CLIENT_SECRET=change_me_get_from_keycloak_client_credentials_tab

# ============================================================
# FLAMENCO WORKERS
# ============================================================
WORKER_REPLICAS=2
WORKER_CPU_LIMIT=4.0
WORKER_MEM_LIMIT=8G
WORKER_CPU_RESERVE=2.0
WORKER_MEM_RESERVE=4G

# ============================================================
# MONITORING
# ============================================================
PROMETHEUS_RETENTION=30d
EXPORTER_SCRAPE_INTERVAL=15
EXPORTER_WORKER_SCRAPE_INTERVAL=15
EXPORTER_TASK_SCRAPE_INTERVAL=60
GPU_EXPORTER_SCRAPE_INTERVAL=5
