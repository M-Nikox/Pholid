# ============================================
# PANGOLIN RENDER MANAGER CONFIGURATION
# ============================================

# Ports
MANAGER_PORT=88
WEB_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Grafana embedding (set to true to enable anonymous panel viewing in the Pangolin UI)
# Safe to enable on local/trusted networks. Review before exposing publicly.
GF_AUTH_ANONYMOUS_ENABLED=false
GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
GF_SECURITY_ALLOW_EMBEDDING=false

# Monitoring
PROMETHEUS_URL=http://prometheus:9090

# Features
# Set to true to enable job deletion (removes from Flamenco AND deletes output files from disk)
# WARNING: Deletion is irreversible. Only enable on trusted networks. Be very careful, please!!!
ENABLE_DELETE=false
# !!!